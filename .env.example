# OpenAI (LLM chat + embedding)
# 留空时, src/llm 和 src/embeddings 都回退到 stub, 骨架仍可端到端跑通。
# Sprint 3 起整个项目用单一 provider (OpenAI), 不再依赖 anthropic。
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 可覆盖, 兼容代理 / 私有部署 (LLM + embedding 共用)
OPENAI_BASE_URL=

# Postgres
# 留空时, src/db 仍可 import; 调用 init_db()/get_session() 时才会真正连接。
# 例: postgresql+psycopg://interview:interview@localhost:5432/interview
POSTGRES_URL=

# Redis (热存储 / 缓存 / Sprint 7 队列 broker)
# 留空时, src/cache 仍可 import; 调用时才连接。
# 例: redis://localhost:6379/0
REDIS_URL=
# 进行中的 InterviewSession 在 Redis 的 TTL, 默认 24h
SESSION_TTL_SECONDS=86400
# LLM 调用结果在 Redis 的 TTL, 默认 7 天; 强刷:
# redis-cli --scan --pattern 'llm:*' | xargs redis-cli DEL
LLM_CACHE_TTL_SECONDS=604800

# Embedding 缓存 TTL, 默认 30 天; 强刷:
# redis-cli --scan --pattern 'emb:*' | xargs redis-cli DEL
EMBEDDING_CACHE_TTL_SECONDS=2592000

# Milvus Lite (本地单文件), 留空时 src/vector_store 仍可 import; 调用才连接。
# 注意: 名字不是 MILVUS_URI —— pymilvus ORM import 时会读 MILVUS_URI 当 http URL
# 解析, 撞上文件路径会 import 期 crash。用 MILVUS_LITE_URI 绕开。
MILVUS_LITE_URI=./milvus_lite.db

# JWT (Sprint 5-1 起 HR 端鉴权)
# 必须 >= 16 字符。dev 随便 hex; prod 用 openssl rand -hex 32
JWT_SECRET=
# access token 有效期, 默认 60 分钟
JWT_EXPIRE_MINUTES=60
# bcrypt 计算 cost. prod 留默认 12; test 可覆盖到 4 让 eval 快
# BCRYPT_ROUNDS=12

# Assessor (Sprint 5.6) — 在线 AnswerAssessment 是否进 production codepath。
# 默认 false: Assessor 代码在仓库里但不参与追问决策, 走 Sprint 0 启发式 _needs_followup;
# evals/test_assessor_calibration 通过 + 人工 review 真 LLM 路径之后, 才在部署层
# 翻 true 启用。即使 true, Assessor 自己 LLM 失败仍走启发式兜底, 永远双路径。
ASSESSOR_ENABLED=false
