# OpenAI (LLM chat + embedding)
# 留空时, src/llm 和 src/embeddings 都回退到 stub, 骨架仍可端到端跑通。
# Sprint 3 起整个项目用单一 provider (OpenAI), 不再依赖 anthropic。
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 可覆盖, 兼容代理 / 私有部署 (LLM + embedding 共用)
OPENAI_BASE_URL=

# Postgres
# 留空时, src/db 仍可 import; 调用 init_db()/get_session() 时才会真正连接。
# 例: postgresql+psycopg://interview:interview@localhost:5432/interview
POSTGRES_URL=

# Test Postgres (Sprint 5.9 patch): evals 强制走这个, 不再共用 POSTGRES_URL。
# 历史背景: evals/test_hr_api / test_auth / test_rag_e2e 会 TRUNCATE 整库,
# 早期共用 POSTGRES_URL 导致跑全量 eval 把 dev 真实 jobs/sessions/reports 抹掉。
# 起 test DB: createdb interview_test
# 例: TEST_POSTGRES_URL=postgresql+psycopg://joy@localhost:5432/interview_test
# 留空时, evals/_test_db.swap_to_test_url() 会把 POSTGRES_URL pop 掉, 所有
# PG-依赖 eval 自动 skip, 也就不会再误删 dev DB。
TEST_POSTGRES_URL=

# Redis (热存储 / 缓存 / Sprint 7 队列 broker)
# 留空时, src/cache 仍可 import; 调用时才连接。
# 例: redis://localhost:6379/0
REDIS_URL=
# 进行中的 InterviewSession 在 Redis 的 TTL, 默认 24h
SESSION_TTL_SECONDS=86400
# LLM 调用结果在 Redis 的 TTL, 默认 7 天; 强刷:
# redis-cli --scan --pattern 'llm:*' | xargs redis-cli DEL
LLM_CACHE_TTL_SECONDS=604800

# Embedding 缓存 TTL, 默认 30 天; 强刷:
# redis-cli --scan --pattern 'emb:*' | xargs redis-cli DEL
EMBEDDING_CACHE_TTL_SECONDS=2592000

# Milvus Lite (本地单文件), 留空时 src/vector_store 仍可 import; 调用才连接。
# 注意: 名字不是 MILVUS_URI —— pymilvus ORM import 时会读 MILVUS_URI 当 http URL
# 解析, 撞上文件路径会 import 期 crash。用 MILVUS_LITE_URI 绕开。
MILVUS_LITE_URI=./milvus_lite.db

# JWT (Sprint 5-1 起 HR 端鉴权)
# 必须 >= 16 字符。dev 随便 hex; prod 用 openssl rand -hex 32
JWT_SECRET=
# access token 有效期, 默认 60 分钟
JWT_EXPIRE_MINUTES=60
# bcrypt 计算 cost. prod 留默认 12; test 可覆盖到 4 让 eval 快
# BCRYPT_ROUNDS=12

# Sprint 5.8: httpOnly cookie 鉴权升级
# Cookie 名 (改名让旧 cookie 自然失效; 默认 auth_token)
JWT_COOKIE_NAME=auth_token
# Secure 标志: dev http 默 false, prod https 必须 true (Secure=true 时浏览器
# 只在 https 上送 cookie, dev localhost http 会送不了)
JWT_COOKIE_SECURE=false

# CORS allowed origins (逗号分隔). 留空时用 dev 默认
# [http://localhost:3000, http://127.0.0.1:3000]. prod 必须 explicit 列出域名,
# 不能用 ["*"] (与 allow_credentials=True 互斥, 浏览器会拒)
CORS_ALLOWED_ORIGINS=

# Assessor (Sprint 5.6, Sprint 5.9 翻默认) — 在线 AnswerAssessment 是否进 production codepath。
# Sprint 5.9 默认 true: 启发式 calibration eval (sufficient vs insufficient gap +0.83;
# covered_aspects mean recall 1.0; distractor precision 1.0) 通过, Assessor 启发式
# fallback 已成回归护栏; LLM 路径任何异常 (超时/JSON/schema) 走启发式, 双路径不变。
# 显式 ASSESSOR_ENABLED=false 仍可关 (eval e2e walk 仍依赖关闭走 Sprint 0 启发式)。
ASSESSOR_ENABLED=true

# 开发者测试: HR 详情页不答题预览全部题目 (含 lazy project 题)。生产必须关闭。
DEV_PLAN_PREVIEW=false

# TTS (Sprint 6-2) — 面试官语音合成, provider 按 region 路由。
# 未配置 = 不合成, 前端静默退纯文字 (文字问答永远是保底路径)。
# 国内 lane: TTS_PROVIDER=volc; 海外 lane: TTS_PROVIDER=azure
TTS_PROVIDER=
# 火山语音 (openspeech.bytedance.com 控制台拿 appid + access token)
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=
# 音色, 默认 BV700_streaming (灿灿); 集群默认 volcano_tts
# VOLC_TTS_VOICE=BV700_streaming
# VOLC_TTS_CLUSTER=volcano_tts
# Azure Speech (portal 拿 key + region, 如 eastasia)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# 音色, 默认 zh-CN-XiaoxiaoNeural (晓晓)
# AZURE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# 合成结果 Redis 缓存 TTL (秒), 默认 7 天
# TTS_CACHE_TTL_SECONDS=604800

# STT (Sprint 6-4) — 候选人语音转写, WS 代理 (厂商 key 不出后端)。
# 未配置 = 前端隐藏麦克风入口, 候选人打字作答 (打字永远是保底路径)。
# 国内 lane: STT_PROVIDER=volc; azure 尚未实装 (海外 lane 先打字)
STT_PROVIDER=
# 火山流式语音识别 (openspeech.bytedance.com 控制台; 与 TTS 是不同的服务项)
VOLC_STT_APPID=
VOLC_STT_TOKEN=
# 集群默认 volcengine_streaming_common
# VOLC_STT_CLUSTER=volcengine_streaming_common

# 录制归档 (Sprint 6-5) — 候选人面试录像落盘目录, 只录不判 (§7)。
# 未配置 = 不录制, consent 文案自动改为"不会录制"。换 S3/MinIO 时
# 重新实现 src/media_store 同名函数即可。
# 留存策略: python -m scripts.cleanup_recordings 挂 cron, 默认 90 天
# (与前端 consent 文案 RETENTION_DAYS 同步, 改一处必须同步另一处)。
MEDIA_STORAGE_DIR=
