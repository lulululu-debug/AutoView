{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); { printf '\\n=== %s | tool=%s ===\\n' \"$(date '+%Y-%m-%d %H:%M:%S')\" \"$(printf '%s' \"$input\" | jq -r '.tool_name')\"; printf '%s' \"$input\" | jq '.tool_input'; } >> $HOME/.claude/projects/-Users-joy-Developer-Auto/file_ops.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\n----- conversation turn ended at %s -----\\n\\n' \"$(date '+%Y-%m-%d %H:%M:%S')\" >> $HOME/.claude/projects/-Users-joy-Developer-Auto/file_ops.log"
          }
        ]
      }
    ]
  }
}
